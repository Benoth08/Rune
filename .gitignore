.env.local
.env.production
.env.*.local
secrets/

# ── IDE ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject

# ── OS ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Venv ───────────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Jupyter ────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── SubAgent workdirs (tmpfs temporaires) ──────────────────────────
rune_subagent_*/
_subagent_main.py

# ── Trinity config (peut contenir des infos sensibles) ─────────────
