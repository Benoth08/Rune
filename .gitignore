*.egg
dist/
build/
.eggs/

# ── Tests / linters ─────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.cache

# ── Données runtime (mémoire, skills, cron, logs) ──────────────────
