data/
!data/.gitkeep

# ── Models / VRAM ──────────────────────────────────────────────────
*.pt
*.bin
*.safetensors
*.gguf
*.onnx

# ── HuggingFace cache ──────────────────────────────────────────────
.cache/
.huggingface/

# ── ChromaDB (vector store — peut être gros) ───────────────────────
chroma/

# ── Logs ───────────────────────────────────────────────────────────
*.log
logs/
data/logs/

# ── Env / secrets ──────────────────────────────────────────────────
