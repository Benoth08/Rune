# ── Modèle (Lythea d'origine) ──────────────────────────────────────
# Model ID HuggingFace par défaut (utilisé si RUNE_AUTOLOAD_MODEL=true)
LYTHEA_MODEL_ID=Qwen/Qwen2.5-7B-Instruct

# ── Rune — Autoload du modèle au boot ─────────────────────────────
# Désactivé par défaut. Si true, charge LYTHEA_MODEL_ID au boot.
# Si false, charge le modèle manuellement via POST /api/models/load.
RUNE_AUTOLOAD_MODEL=false
RUNE_DEFAULT_MODEL=Qwen/Qwen2.5-7B-Instruct

# ── Rune — Auto-install Node.js ───────────────────────────────────
# Si true, installe Node.js automatiquement au boot si manquant.
# Désactivé si tu veux gérer Node toi-même.
RUNE_AUTO_INSTALL_NODE=true

# ── Rune — Trinity (pool multi-modèles) ───────────────────────────
# Désactivé par défaut. Pour activer :
# 1. Crée un fichier trinity.yaml (utilise rune trinity init pour le template)
# 2. Set RUNE_TRINITY_CONFIG=chemin/vers/trinity.yaml
# Voir trinity.yaml pour la config des 3 modèles (Thinker/Worker/Critic).
# RUNE_TRINITY_CONFIG=data/trinity.yaml

# ── Auth (Lythea d'origine) ───────────────────────────────────────
# Token d'authentification (vide = serveur OPEN, pas safe en prod)
LYTHEA_AUTH_TOKEN=
# Strict mode : si true, token requis même en loopback (localhost).
# Si false, loopback bypass le token (recommandé pour dev).
LYTHEA_AUTH_STRICT=false

# ── Spéculative decoding (Rune) ───────────────────────────────────
# Active le speculative decoding (draft model + verify) pour 2-3× vitesse.
LYTHEA_SPEC_DECODING=true
LYTHEA_DRAFT_MODEL=Qwen/Qwen3-0.6B

# ── Web search (Lythea d'origine) ─────────────────────────────────
# Provider : ddg (gratuit, pas de clé) | brave | searxng | serper | tavily
LYTHEA_WEB_PROVIDER=ddg
# LYTHEA_BRAVE_API_KEY=
# LYTHEA_SERPER_API_KEY=
# LYTHEA_TAVILY_API_KEY=

# ── Cascade extérieure (Rune — optionnel) ─────────────────────────
# Désactivée par défaut. Permet d'utiliser un modèle distant (Gemini ou
# Claude) comme "draft consultant" — le draft est ensuite resynthétisé
# localement par le modèle principal. Le distant ne parle jamais
# directement à l'utilisateur.
#
# Provider : gemini (défaut) | claude | (futur: openai, mistral)
RUNE_ENABLE_CASCADE=false
RUNE_CASCADE_PROVIDER=gemini

# Pour Gemini (Google AI Studio — https://aistudio.google.com/app/apikey)
# GOOGLE_API_KEY=AIzaSy...

# Pour Claude (Anthropic — https://console.anthropic.com/settings/keys)
# ANTHROPIC_API_KEY=sk-ant-...
# RUNE_CASCADE_CLAUDE_MODEL=claude-sonnet-4-20250514

# Modèle Gemini (défaut: gemini-3.5-flash, free tier 1500 req/jour)
# LYTHEA_CASCADE_GEMINI_MODEL=gemini-3.5-flash

# ── Channels (Rune) ───────────────────────────────────────────────
# LYTHEA_TELEGRAM_TOKEN=
# LYTHEA_SLACK_APP_TOKEN=
# LYTHEA_SLACK_BOT_TOKEN=

# ── Logging ───────────────────────────────────────────────────────
LYTHEA_LOG_LEVEL=INFO
LYTHEA_LOG_FORMAT=console

# ── HuggingFace (recommandé pour téléchargements plus rapides) ────
# Crée un token sur https://huggingface.co/settings/tokens (read gratuit)
# HF_TOKEN=hf_xxx...
